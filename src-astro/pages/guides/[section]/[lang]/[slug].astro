---
/**
 * /guides/[section]/[lang]/[slug] — GEO静的ガイド（作業指示書のURL規約 /guides/{section}/{lang}/{slug}）
 * 描画順: directAnswer(Summary)→CTA→本文(MD)→実地レポート→プラン表(SSOT)→競合表(SSOT)→FAQ→CTA。
 * 価格の数値は feed に無く、Firestore(plans/competitorPlans) から焼く。購入は /app?open=true&plan= へdeep-link。
 */
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getEsimGuides, stripTitlePrefix, type EsimGuide } from "../../../../lib/esimGuides";
import { getPlansByBindings, type Plan } from "../../../../lib/plans";
import { getCompetitorTable, type CompareTable } from "../../../../lib/competitor";
import { renderMarkdown } from "../../../../lib/markdown";
import { getUi, formatAsOf, formatCompareNote, formatUpdated } from "../../../../lib/ui-i18n";

export async function getStaticPaths() {
  const guides = await getEsimGuides();
  const paths: {
    params: { section: string; lang: string; slug: string };
    props: { guide: EsimGuide; lang: string; section: string };
  }[] = [];
  for (const guide of guides) {
    const section = guide.categorySlug || "esim";
    for (const lang of guide.languages ?? []) {
      if (!guide.translations?.[lang]) continue;
      paths.push({ params: { section, lang, slug: guide.slug }, props: { guide, lang, section } });
    }
  }
  return paths;
}

const { guide, lang, section } = Astro.props as { guide: EsimGuide; lang: string; section: string };
const t = guide.translations[lang];
const ui = getUi(lang);

const displayTitle = stripTitlePrefix(t.title);
const metaTitle = t.metaTitle || displayTitle;
const metaDescription = t.metaDescription || t.excerpt || "";
const bodyHtml = renderMarkdown(t.body || "");

// 実地レポート（一次データ）。非nullなら本文直後に緑枠で描画（画像込み）。
const fieldReportHtml = guide.fieldReport ? renderMarkdown(guide.fieldReport) : null;

// SSOT からプラン表を焼く
const plans: Plan[] = await getPlansByBindings(guide.priceBindings ?? []);
const yen = (n: number | null) => (n == null ? "—" : `¥${n.toLocaleString("ja-JP")}`);

// 競合比較表（SSOT: competitorPlans/main）。feed の showCompetitorTable が真のときのみ。
const competitor: CompareTable | null = guide.showCompetitorTable === true ? await getCompetitorTable() : null;

// 料金基準日キャプション（言語別）
const asOfLabel = formatAsOf(lang, guide.confirmedDate);
const compareNote = formatCompareNote(lang, guide.confirmedDate);

// canonical(絶対) と hreflang — /guides/{section}/{lang}/{slug}（ヘッドが所有・feedのcanonicalは参照しない）
const site = Astro.site ?? new URL("https://yah.mobi");
const guidePath = (l: string) => `/guides/${section}/${l}/${guide.slug}`;
const canonical = new URL(guidePath(lang), site).href;
const alternates = (guide.languages ?? []).map((l) => ({ lang: l, href: new URL(guidePath(l), site).href }));

// deep-link（既存SPAドロワー起動）
const buyHref = (planId: string) => `/app?open=true&plan=${encodeURIComponent(planId)}`;
const primaryPlanId = plans[0]?.id;
// 要約直下CTAの価格（バインド中プランの最安・SSOTから焼く。ハードコードしない）
const leadPrices = plans.map((p) => p.priceJpy).filter((n): n is number => n != null);
const leadPrice = leadPrices.length ? Math.min(...leadPrices) : null;

// 著者バイライン（表示 ＋ JSON-LD Person）。author はオブジェクト {name,title,photoUrl}。
const author = guide.author?.name ? guide.author : null;
const updatedText = formatUpdated(lang, guide.updatedAt);

// JSON-LD（Article + FAQPage）
const iso = (ms?: number) => (ms ? new Date(ms).toISOString() : undefined);
const authorLd = author
  ? {
      "@type": "Person",
      name: author.name,
      ...(author.title ? { jobTitle: author.title } : {}),
      ...(author.photoUrl ? { image: author.photoUrl } : {}),
    }
  : { "@type": "Organization", name: "yah.mobile" };
const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": guide.schemaType || "Article",
  headline: displayTitle,
  description: metaDescription,
  inLanguage: lang,
  mainEntityOfPage: canonical,
  author: authorLd,
  publisher: { "@type": "Organization", name: "yah.mobile" },
};
if (iso(guide.publishedAt)) articleLd.datePublished = iso(guide.publishedAt);
if (iso(guide.updatedAt)) articleLd.dateModified = iso(guide.updatedAt);
if (guide.thumbnailUrl) articleLd.image = guide.thumbnailUrl;

const faqLd =
  t.faq && t.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: t.faq.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: { "@type": "Answer", text: f.a },
        })),
      }
    : null;
const jsonLd = [articleLd, ...(faqLd ? [faqLd] : [])];
---
<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical={canonical}
  lang={lang}
  ogImage={guide.thumbnailUrl}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <article>
    <h1>{displayTitle}</h1>

    {(author || updatedText) && (
      <div class="byline">
        {author?.photoUrl && (
          <img class="byline-photo" src={author.photoUrl} alt={author.name} width="40" height="40" loading="lazy" decoding="async" />
        )}
        {author && (
          <div class="byline-meta">
            <span class="byline-name">{author.name}</span>
            {author.title && <span class="byline-title">{author.title}</span>}
          </div>
        )}
        {updatedText && <span class="byline-date">{updatedText}</span>}
      </div>
    )}

    {t.directAnswer && (
      <div class="direct-answer">
        <span class="direct-answer-label">{ui.summaryLabel}</span>
        <p>{t.directAnswer}</p>
      </div>
    )}

    {primaryPlanId && (
      <aside class="lead-cta">
        <p class="lead-cta-head">{ui.ctaHeadline}</p>
        <a class="lead-cta-btn" href={buyHref(primaryPlanId)} data-plan={primaryPlanId}>
          {ui.ctaButton}{leadPrice != null ? `（${yen(leadPrice)}〜）` : ""}
        </a>
      </aside>
    )}

    <div class="article-body" set:html={bodyHtml} />

    {fieldReportHtml && (
      <section class="field-report" aria-label={ui.fieldReportTitle}>
        <h2 class="fr-title">
          {ui.fieldReportTitle}
          {guide.fieldReportMode === "field" && <span class="fr-badge">{ui.fieldReportField}</span>}
          {guide.fieldReportMode === "assumed" && <span class="fr-badge fr-assumed">{ui.fieldReportAssumed}</span>}
        </h2>
        <div class="fr-body article-body" set:html={fieldReportHtml} />
      </section>
    )}

    {plans.length > 0 && (
      <section aria-label={ui.plansTitle} class="plans-section">
        <h2>{ui.plansTitle}</h2>
        <table class="plans">
          <thead>
            <tr>
              <th>{ui.colPlan}</th>
              <th>{ui.colData}</th>
              <th>{ui.colValidity}</th>
              <th>{ui.colPrice}</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {plans.map((p) => (
              <tr>
                <td>{p.name}</td>
                <td>{p.dataGb != null ? `${p.dataGb}GB` : "—"}</td>
                <td>{p.validityDays != null ? `${p.validityDays}${lang === "ja" ? "日" : " days"}` : "—"}</td>
                <td class="plan-price">{yen(p.priceJpy)}</td>
                <td><a class="buy-btn" href={buyHref(p.id)}>{ui.buy}</a></td>
              </tr>
            ))}
          </tbody>
        </table>
        {asOfLabel && <p class="table-caption">{asOfLabel}</p>}
      </section>
    )}

    {competitor && (
      <section class="compare" aria-label={ui.compareTitle}>
        <h2>{ui.compareTitle}</h2>
        <div class="compare-scroll">
          <table class="compare-table">
            <thead>
              <tr>{competitor.columns.map((c) => <th>{c.label}</th>)}</tr>
            </thead>
            <tbody>
              {competitor.rows.map((row) => (
                <tr class={row.highlight ? "is-hl" : ""}>
                  {competitor.columns.map((col, ci) => {
                    const val = String(row[col.colKey] ?? "");
                    if (col.colKey === "service" || ci === 0) {
                      return <td class="c-service">{val}</td>;
                    }
                    if (col.colKey === "pricePerGb" && row.highlight) {
                      return (
                        <td>
                          <span class="c-pricegb">{val}</span>
                          <span class="c-best">{ui.bestValue}</span>
                        </td>
                      );
                    }
                    return <td>{val}</td>;
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {compareNote && <p class="table-caption">{compareNote}</p>}
      </section>
    )}

    {t.faq && t.faq.length > 0 && (
      <section class="faq" aria-label={ui.faqTitle}>
        <h2>{ui.faqTitle}</h2>
        {t.faq.map((f) => (
          <div>
            <h3>{f.q}</h3>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </section>
    )}

    {primaryPlanId && (
      <div class="cta-row">
        <a class="buy-btn" href={buyHref(primaryPlanId)}>{ui.buyCta}</a>
      </div>
    )}
  </article>
</BaseLayout>
